# Agades PQC Gym local environment template.
# Copy to .env or edit the ignored local .env file. Never commit real secrets.

# Prime Intellect
PRIME_API_KEY=
# Prime team ID, not the display name. Example format: cmp...
PRIME_ORG=
PRIME_ENVIRONMENT_SLUG=agades-pqc-verifier-env
PRIME_VISIBILITY=PRIVATE

# Hugging Face
HF_TOKEN=
HF_ORG=agades
HF_SPACE_NAME=agades-pqc-gym
HF_SPACE_VISIBILITY=private

# NVIDIA / accelerator review
NVIDIA_API_KEY=
NVIDIA_ORG=

# Optional model/runtime providers
OPENAI_API_KEY=
WANDB_API_KEY=

# Private model and RL assets. Keep these paths private and untracked.
AGADES_PRIVATE_DATA_ROOT=private/datasets
AGADES_PRIVATE_TRACE_ROOT=private/traces
AGADES_PRIVATE_MODEL_ROOT=private/models
AGADES_QWEN_BASE_MODEL=
AGADES_QWEN_ARTIFACT_PLAN=private/reports/qwen/artifact_plan.json
AGADES_QWEN_GGUF_OTQ_5BIT_PATH=
AGADES_QWEN_LORA_ADAPTER_PATH=

# Formal backend tooling
AGADES_LEAN4_BIN=lean
AGADES_LAKE_BIN=lake
AGADES_Z3_BIN=z3
