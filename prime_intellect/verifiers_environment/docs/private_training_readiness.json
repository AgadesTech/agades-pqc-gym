      "status": "blocked"
    },
    {
      "blocks_launch": true,
      "evidence_required": "GGUF OTQ 5-bit is a private target artifact; training must use reviewed trainable weights or adapters before private quantization.",
      "id": "private_qwen_trainable_weights_available",
      "status": "blocked"
    },
    {
      "blocks_launch": true,
      "evidence_required": "Each source in docs/private_dataset_curation.json must have a completed license review before ingestion.",
      "id": "dataset_license_review_complete",
      "status": "blocked"
    },
    {
      "blocks_launch": true,
      "evidence_required": "Private per-row provenance and hash manifests must exist before training.",
      "id": "dataset_provenance_manifest_complete",
      "status": "blocked"
    },
    {
      "blocks_launch": true,
      "evidence_required": "Private exact, normalized, and near-duplicate reports must prove cross-source deduplication before training.",
      "id": "dataset_deduplication_report_complete",
      "status": "blocked"
    },
    {
      "blocks_launch": true,
      "evidence_required": "Private redaction report must prove credentials, personal data, and unlicensed spans were removed.",
      "id": "dataset_redaction_report_complete",
      "status": "blocked"
    },
    {
      "blocks_launch": true,
      "evidence_required": "Private contamination report must reject public overlap and prompt or reviewer-annotation leakage.",
      "id": "dataset_contamination_audit_complete",
      "status": "blocked"
    },
    {
      "blocks_launch": true,
      "evidence_required": "Pedagogical RL traces require reviewer-quality and no-overclaim signals before Qwen fine-tuning.",
      "id": "pedagogical_trace_quality_review_complete",
      "status": "blocked"
    },
    {
      "blocks_launch": true,
      "evidence_required": "Prime org, environment, private storage, and visibility must be reviewed out of band.",
      "id": "prime_private_training_environment_reviewed",
      "status": "blocked"
    },
    {
      "blocks_launch": true,
      "evidence_required": "Formal obligations and family invariants must be checked against the private trace task mix.",
      "id": "formal_obligation_coverage_reviewed",
      "status": "blocked"
    },
    {
      "blocks_launch": true,
      "evidence_required": "Domain reviewers must be assigned before private claims or training promotion.",
      "id": "cryptography_domain_reviewers_assigned",
      "status": "blocked"
    }
  ],
  "release_gates": [
    "uv run pytest tests/test_private_training_readiness.py -q",
