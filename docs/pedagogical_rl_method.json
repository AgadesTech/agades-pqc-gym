  "method": {
    "base_paradigm": "learn_nearest_successes_from_privileged_context",
    "domain": "AttackPlan_generation_validation_and_repair",
    "private_outputs_only": true,
    "public_training_claim": "agents learn to produce formally valid and reviewable AttackPlans, not cryptographic break claims",
    "teacher_student_pattern": "privileged_self_teacher_student"
  },
  "privacy": {
    "fine_tuned_weights_publication_allowed": false,
    "raw_rollouts_publication_allowed": false,
    "reviewer_annotations_publication_allowed": false,
    "sanitized_metadata_cards_allowed": true,
    "student_logprobs_publication_allowed": false,
    "teacher_prompts_publication_allowed": false
  },
  "private_trace_contract": {
    "forbidden_public_fields": [
      "teacher_prompt",
      "teacher_completion",
      "student_prompt",
      "student_token_logprobs",
      "surprise_gaps",
      "reviewer_annotations",
      "raw_dataset_rows"
    ],
    "public_release_ok": false,
    "quality_gates": [
      "attackplan_schema_valid",
      "formal_artifact_attached",
      "proof_obligations_typed",
      "dataset_license_reviewed",
      "provenance_captured",
      "human_crypto_review_required",
      "publication_boundary_review_required"
    ],
    "raw_private_signals_included": false,
    "record_kind": "private_teacher_student_trace",
    "required_bindings": {
      "dataset_curation_manifest_path": "docs/private_dataset_curation.json",
      "formal_artifact_binding_schema": "agades.pqc.rl.formal_artifact_binding.v1",
      "formal_obligation_ledger_path": "docs/formal_obligation_ledger.json",
      "pedagogical_reward_schema": "agades.pqc.rl.pedagogical_reward.v1",
      "reviewer_governance_manifest_path": "docs/reviewer_governance.json",
      "reward_report_schema": "agades.pqc.rl.reward_report.v1"
    },
    "required_record_fields": [
      "trace_id",
      "task_digest",
      "candidate_digest",
      "reward_report_digest",
      "pedagogical_reward",
      "formal_artifact_binding",
      "dataset_curation_digest",
      "review_gate",
      "privacy_boundary"
    ],
    "schema_version": "agades.pqc.rl.private_pedagogical_trace.v1",
    "storage_roots": [
      "private/traces/pedagogical_rl",
      "private/datasets/agades_pedagogical_rl"
    ]
  },
  "project": {
    "name": "Agades PQC Gym",
    "package": "agades_pqc_gym",
    "repository": "https://github.com/AgadesTech/agades-pqc-gym"
  },
  "publication_boundary": {
    "forbidden_public_claims": [
      "unreviewed_pqc_break_claims",
      "private_qwen_weights_or_adapters",
      "private_training_traces_or_reviewer_annotations",
      "private_dataset_rows_or_prompts"
    ],
    "public_claims_allowed": [
      "environment_scoring_contracts",
      "sanitized_metadata_cards",
      "toy_or_schema_only_rollout_examples"
    ]
  },
  "release_gates": [
    "uv run pytest tests/test_pedagogical_rl_method.py -q",
    "uv run agades-pqc pedagogical-rl-method --out docs/pedagogical_rl_method.json",
    "uv run agades-pqc pedagogical-rl-method-verify --method docs/pedagogical_rl_method.json",
    "uv run agades-pqc private-dataset-curation-verify --curation docs/private_dataset_curation.json",
    "uv run agades-pqc private-training-config-verify --config prime_intellect/training/private_qwen_prime_rl.template.toml --manifest docs/private_training_config_manifest.json",
    "uv run agades-pqc rl-environment-contract-verify --contract docs/rl_environment_contract.json",
    "uv run agades-pqc reviewer-governance-verify --governance docs/reviewer_governance.json",
    "uv run agades-pqc ecosystem-smoke-verify --report reports/ecosystem_smoke.json",
    "uv run agades-pqc release-audit --out public/release_audit.json"
  ],
  "reward_contract": {
    "claim_boundary": {
      "allows_security_claims": false,
      "formal_obligation_ledger_path": "docs/formal_obligation_ledger.json",
      "requires_formal_obligations": true,
      "requires_human_crypto_review": true
    },
    "learnability_score": {
      "beta": 5.0,
      "formula": "exp(-(lambda/beta) * log(mean_t(exp(beta * d_t))))",
      "lambda": 1.0,
      "surprise_gap": "log p_student(a_max|x,prefix) - log p_student(a_t|x,prefix)",
      "type": "spike_aware_logsumexp_surprise_gap"
    },
    "pedagogy_reward": "R_agades(x,c,tau) * G_spike_student(tau|x)",
    "range": [
      0.0,
      1.0
    ],
    "runtime_binding": {
      "assimilation_weight_function": "agades_pqc_gym.rl.pedagogy.surprisal_gated_token_weights",
      "learnability_function": "agades_pqc_gym.rl.pedagogy.spike_aware_learnability_score",
      "raw_private_signals_publication_allowed": false,
      "reward_function": "agades_pqc_gym.rl.pedagogy.build_pedagogical_reward_report",
      "reward_report_schema": "agades.pqc.rl.pedagogical_reward.v1"
    },
    "success_gate": {
      "good_answer_only_is_sufficient": false,
      "required_terms": [
        "formal_validity",
        "cryptographic_applicability",
        "no_security_overclaim",
        "student_readability",
        "reproducibility",
        "reviewer_quality",
        "task_match",
        "proof_obligation_coverage"
      ],
      "term_definitions": {
        "cryptographic_applicability": "candidate passes the public verifier for its target family and operator",
        "formal_validity": "candidate parses as an AttackPlan and produces a proof artifact",
        "no_security_overclaim": "candidate does not publish unreviewed estimates, success probability, external claims, or PQC break claims",
        "proof_obligation_coverage": "candidate proof artifact has family invariants, proof obligations, and every proof obligation is bound to a Lean-backed type_rule",
        "reproducibility": "candidate satisfies the task reproducibility requirement when present",
        "reviewer_quality": "candidate proof artifact names required reviewer roles and preserves the release claim boundary",
        "student_readability": "candidate is a single readable JSON object with notes that state the no-security-claim boundary",
        "task_match": "candidate target family, target name, support level, and operator sequence match the task metadata"
      },
      "type": "agades_verifier_and_reviewer_gate"
    },
    "type": "multiplicative_pedagogical_reward"
  },
  "roles": {
    "self_teacher": {
      "conditioning": "attackplan_prompt_with_privileged_context",
      "model": "Qwen3.6-27B-private",
      "must_remain_student_learnable": true,
      "privileged_context": [
        "formal_obligations",
        "family_invariants",
        "estimator_results",
        "reviewer_rubric",
        "license_and_provenance_metadata"
      ],
      "privileged_context_visible": true
    },
    "student": {
      "conditioning": "attackplan_prompt_without_privileged_context",
      "model": "Qwen3.6-27B-private",
      "private_outputs_only": true,
      "privileged_context_visible": false
    }
  },
  "schema_version": "agades.pqc.pedagogical_rl_method.v1",
  "source": {
    "citation_key": "chakraborty_ziems_2026_pedagogical_rl",
    "name": "Pedagogical RL",
    "url": "https://noahziems.com/pedagogical-rl"
  },
  "stages": [
    {
      "external_publication_allowed": false,
      "id": "privileged_self_teacher_grpo",
      "objective": "R_agades(x,c,tau) * G_spike_student(tau|x)",
      "policy": "self_teacher",
      "trainer": "prime-rl",
      "uses_privileged_context": true
    },
    {
      "id": "spike_aware_trajectory_filter",
      "objective": "spike_aware_logsumexp_surprise_gap",
      "policy": "student_scorer",
      "raw_logits_publication_allowed": false,
      "uses_student_logprobs": true
    },
    {
      "id": "surprisal_gated_student_assimilation",
      "objective": "surprisal_gated_imitation",
      "policy": "student",
      "raw_teacher_tokens_publication_allowed": false,
      "update": "weighted_sft"
    },
    {
      "external_publication_allowed": false,
      "id": "optional_private_grpo_refinement",
      "objective": "R_agades(x,c,tau)",
      "policy": "student",
      "requires_prior_method_artifact": true
    }
  ]
}
